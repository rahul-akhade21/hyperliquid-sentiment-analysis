
```json
{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Hyperliquid Trader Performance vs. Market Sentiment\n",
    "## Complete Analysis Notebook\n",
    "\n",
    "**Objective**: Explore the relationship between trader performance and the Fear & Greed Index\n",
    "\n",
    "**Data Sources**:\n",
    "- Historical Trader Data from Hyperliquid\n",
    "- Bitcoin Fear & Greed Index"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy.stats import spearmanr, mannwhitneyu\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set plotting style\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")\n",
    "print(\"✅ Libraries imported successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load datasets\n",
    "sentiment = pd.read_csv('fear_greed_index.csv')\n",
    "trades = pd.read_csv('historical_data.csv')\n",
    "\n",
    "print(f\"Sentiment data shape: {sentiment.shape}\")\n",
    "print(f\"Trade data shape: {trades.shape}\")\n",
    "print(\"\\n📊 Sample of sentiment data:\")\n",
    "print(sentiment.head())\n",
    "print(\"\\n📊 Sample of trade data:\")\n",
    "print(trades.head())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Data Cleaning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clean sentiment data\n",
    "sentiment['date'] = pd.to_datetime(sentiment['date']).dt.date\n",
    "\n",
    "# Clean trade data\n",
    "trades['Timestamp IST'] = pd.to_datetime(trades['Timestamp IST'], format='%d-%m-%Y %H:%M')\n",
    "trades['date'] = trades['Timestamp IST'].dt.date\n",
    "trades['Closed PnL'] = pd.to_numeric(trades['Closed PnL'], errors='coerce')\n",
    "trades['Size USD'] = pd.to_numeric(trades['Size USD'], errors='coerce')\n",
    "trades['leverage'] = pd.to_numeric(trades['leverage'], errors='coerce')\n",
    "\n",
    "# Filter out dust conversions and missing PnL\n",
    "trades = trades[trades['Closed PnL'].notna()]\n",
    "trades = trades[trades['Direction'] != 'Spot Dust Conversion']\n",
    "\n",
    "print(f\"✅ Cleaned trade data shape: {trades.shape}\")\n",
    "print(f\"\\n📊 Unique accounts: {trades['Account'].nunique()}\")\n",
    "print(f\"📊 Unique coins: {trades['Coin'].nunique()}\")\n",
    "print(f\"📊 Date range: {trades['date'].min()} to {trades['date'].max()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Merge Datasets"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge on date\n",
    "merged = trades.merge(\n",
    "    sentiment[['date', 'classification', 'value']],\n",
    "    on='date',\n",
    "    how='left'\n",
    ")\n",
    "merged = merged[merged['classification'].notna()]\n",
    "\n",
    "print(f\"✅ Merged data shape: {merged.shape}\")\n",
    "print(f\"\\n📊 Sentiment distribution:\")\n",
    "print(merged['classification'].value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create numeric sentiment score\n",
    "sentiment_order = {'Extreme Fear': 0, 'Fear': 1, 'Neutral': 2, 'Greed': 3, 'Extreme Greed': 4}\n",
    "merged['sentiment_score'] = merged['classification'].map(sentiment_order)\n",
    "\n",
    "# Create profitability flag\n",
    "merged['profitable'] = merged['Closed PnL'] > 0\n",
    "\n",
    "# Extract trading session\n",
    "merged['hour'] = merged['Timestamp IST'].dt.hour\n",
    "merged['session'] = merged['hour'].apply(\n",
    "    lambda h: 'Asia' if 0 <= h < 8 else ('Europe' if 8 <= h < 16 else 'US')\n",
    ")\n",
    "\n",
    "# Categorize trade size\n",
    "merged['size_tier'] = pd.cut(\n",
    "    merged['Size USD'],\n",
    "    bins=[0, 1000, 10000, np.inf],\n",
    "    labels=['Small (<$1k)', 'Medium ($1k-$10k)', 'Large (>$10k)']\n",
    ")\n",
    "\n",
    "# Calculate PnL per USD size (efficiency metric)\n",
    "merged['pnl_per_dollar'] = merged['Closed PnL'] / merged['Size USD']\n",
    "\n",
    "print(\"✅ Feature engineering complete\")\n",
    "print(f\"\\n📊 Feature summary:\")\n",
    "print(f\"- Sentiment score range: {merged['sentiment_score'].min()} to {merged['sentiment_score'].max()}\")\n",
    "print(f\"- Overall profit rate: {merged['profitable'].mean():.2%}\")\n",
    "print(f\"- Sessions: {merged['session'].unique()}\")\n",
    "print(f\"- Size tiers: {merged['size_tier'].unique()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Core Analysis: Sentiment vs. PnL"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary by sentiment\n",
    "summary = merged.groupby('classification').agg({\n",
    "    'Closed PnL': ['mean', 'median', 'std', 'count'],\n",
    "    'profitable': 'mean',\n",
    "    'Size USD': 'mean',\n",
    "    'leverage': 'mean'\n",
    "}).round(2)\n",
    "\n",
    "summary.columns = ['Mean PnL', 'Median PnL', 'Std PnL', 'Trade Count', 'Win Rate', 'Avg Size', 'Avg Leverage']\n",
    "print(\"=\"*80)\n",
    "print(\"📊 PERFORMANCE BY SENTIMENT\")\n",
    "print(\"=\"*80)\n",
    "print(summary)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization 1: Boxplot\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "\n",
    "# Boxplot\n",
    "sns.boxplot(data=merged, x='classification', y='Closed PnL', ax=axes[0])\n",
    "axes[0].set_title('PnL Distribution by Sentiment', fontsize=14, fontweight='bold')\n",
    "axes[0].set_yscale('symlog')\n",
    "axes[0].axhline(y=0, color='red', linestyle='--', alpha=0.5)\n",
    "axes[0].tick_params(axis='x', rotation=45)\n",
    "axes[0].set_ylabel('Closed PnL ($)')\n",
    "\n",
    "# Win rate bar chart\n",
    "win_rate = merged.groupby('classification')['profitable'].mean()\n",
    "colors = ['darkred', 'red', 'gray', 'lightgreen', 'green']\n",
    "win_rate.plot(kind='bar', ax=axes[1], color=colors, edgecolor='black')\n",
    "axes[1].set_title('Win Rate by Sentiment', fontsize=14, fontweight='bold')\n",
    "axes[1].set_ylabel('Win Rate')\n",
    "axes[1].set_ylim(0, 0.8)\n",
    "axes[1].axhline(y=0.5, color='black', linestyle='--', label='50% Random')\n",
    "axes[1].legend()\n",
    "for i, v in enumerate(win_rate):\n",
    "    axes[1].text(i, v + 0.02, f'{v:.0%}', ha='center', va='bottom', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('pnl_by_sentiment.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Visualization saved: pnl_by_sentiment.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Statistical Validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mann-Whitney U Test\n",
    "fear_pnl = merged[merged['classification'] == 'Fear']['Closed PnL']\n",
    "greed_pnl = merged[merged['classification'] == 'Greed']['Closed PnL']\n",
    "extreme_greed_pnl = merged[merged['classification'] == 'Extreme Greed']['Closed PnL']\n",
    "\n",
    "stat, p_fear_greed = mannwhitneyu(fear_pnl, greed_pnl, alternative='two-sided')\n",
    "stat, p_fear_extreme = mannwhitneyu(fear_pnl, extreme_greed_pnl, alternative='two-sided')\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"📊 STATISTICAL VALIDATION\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Fear vs Greed p-value: {p_fear_greed:.6f}\")\n",
    "print(f\"Fear vs Extreme Greed p-value: {p_fear_extreme:.6f}\")\n",
    "\n",
    "# Spearman Correlation\n",
    "corr, p_corr = spearmanr(merged['sentiment_score'], merged['Closed PnL'])\n",
    "print(f\"\\nSpearman Correlation: {corr:.3f}\")\n",
    "print(f\"Correlation p-value: {p_corr:.6f}\")\n",
    "\n",
    "# Interpretation\n",
    "if p_fear_greed < 0.05 and p_fear_extreme < 0.05:\n",
    "    print(\"\\n✅ Statistical Conclusion: The difference is SIGNIFICANT (p < 0.05)\")\n",
    "    print(\"✅ The relationship is NOT random\")\n",
    "else:\n",
    "    print(\"\\n❌ No statistical significance found\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Whale vs. Small Trader Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identify traders\n",
    "avg_size_by_account = trades.groupby('Account')['Size USD'].mean()\n",
    "whale_accounts = avg_size_by_account[avg_size_by_account > 10000].index.tolist()\n",
    "merged['trader_type'] = merged['Account'].apply(\n",
    "    lambda x: 'Whale' if x in whale_accounts else 'Small'\n",
    ")\n",
    "\n",
    "# Performance comparison\n",
    "trader_sentiment = merged.groupby(['trader_type', 'classification'])['Closed PnL'].mean().unstack()\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"📊 WHALE vs. SMALL TRADER PnL\")\n",
    "print(\"=\"*60)\n",
    "print(trader_sentiment.round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "trader_sentiment.T.plot(kind='bar', ax=ax)\n",
    "ax.set_title('Trader Type Performance by Sentiment', fontsize=14, fontweight='bold')\n",
    "ax.set_ylabel('Mean PnL ($)')\n",
    "ax.set_xlabel('Sentiment')\n",
    "ax.axhline(y=0, color='black', linestyle='--', alpha=0.5)\n",
    "ax.legend(title='Trader Type')\n",
    "plt.tight_layout()\n",
    "plt.savefig('whale_vs_small.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Visualization saved: whale_vs_small.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Leverage Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "leverage_by_sentiment = merged.groupby('classification')['leverage'].mean().round(2)\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"📊 AVERAGE LEVERAGE BY SENTIMENT\")\n",
    "print(\"=\"*60)\n",
    "print(leverage_by_sentiment)\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "colors = ['darkred', 'red', 'gray', 'lightgreen', 'green']\n",
    "leverage_by_sentiment.plot(kind='bar', color=colors, ax=ax, edgecolor='black')\n",
    "ax.set_title('Average Leverage Used by Sentiment', fontsize=14, fontweight='bold')\n",
    "ax.set_ylabel('Average Leverage (x)')\n",
    "ax.set_xlabel('Sentiment')\n",
    "for i, v in enumerate(leverage_by_sentiment):\n",
    "    ax.text(i, v + 0.3, f'{v:.1f}x', ha='center', va='bottom', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('leverage_by_sentiment.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Visualization saved: leverage_by_sentiment.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Session Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "session_perf = merged.groupby(['session', 'classification'])['Closed PnL'].mean().unstack()\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"📊 PnL BY SESSION AND SENTIMENT\")\n",
    "print(\"=\"*60)\n",
    "print(session_perf.round(2))\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "session_perf.plot(kind='bar', ax=ax)\n",
    "ax.set_title('PnL by Session and Sentiment', fontsize=14, fontweight='bold')\n",
    "ax.set_ylabel('Mean PnL ($)')\n",
    "ax.set_xlabel('Trading Session')\n",
    "ax.axhline(y=0, color='black', linestyle='--', alpha=0.5)\n",
    "ax.legend(title='Sentiment', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "plt.tight_layout()\n",
    "plt.savefig('session_analysis.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Visualization saved: session_analysis.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Strategy Backtest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Contrarian Strategy\n",
    "merged['signal'] = merged['classification'].apply(\n",
    "    lambda x: 1 if x in ['Fear', 'Extreme Fear'] else (-1 if x in ['Greed', 'Extreme Greed'] else 0)\n",
    ")\n",
    "strategy = merged[merged['signal'] != 0].copy()\n",
    "strategy['strategy_return'] = strategy['Closed PnL'] * strategy['signal']\n",
    "\n",
    "# Benchmarks\n",
    "buy_hold_pnl = merged['Closed PnL'].sum()\n",
    "strategy_pnl = strategy['strategy_return'].sum()\n",
    "strategy_win_rate = (strategy['strategy_return'] > 0).mean()\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"📊 STRATEGY BACKTEST RESULTS\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Contrarian Strategy (Buy Fear / Sell Greed):\")\n",
    "print(f\"  - Win Rate: {strategy_win_rate:.2%}\")\n",
    "print(f\"  - Total PnL: ${strategy_pnl:,.2f}\")\n",
    "print(f\"  - Number of Trades: {len(strategy)}\")\n",
    "print(f\"\\nBuy & Hold (All Trades):\")\n",
    "print(f\"  - Total PnL: ${buy_hold_pnl:,.2f}\")\n",
    "print(f\"\\n🚀 Strategy outperforms buy-and-hold by {(strategy_pnl/buy_hold_pnl):.1f}x\")\n",
    "\n",
    "# Session-specific\n",
    "us_strategy = strategy[strategy['session'] == 'US']\n",
    "us_win_rate = (us_strategy['strategy_return'] > 0).mean()\n",
    "print(f\"\\n📍 US Session Performance:\")\n",
    "print(f\"  - Win Rate: {us_win_rate:.2%}\")\n",
    "print(f\"  - Trades: {len(us_strategy)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 12. Correlation Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Select numerical columns\n",
    "corr_cols = ['sentiment_score', 'Closed PnL', 'Size USD', 'leverage', 'pnl_per_dollar']\n",
    "corr_data = merged[corr_cols].copy()\n",
    "corr_data['profitable'] = merged['profitable'].astype(int)\n",
    "\n",
    "# Compute correlation\n",
    "corr_matrix = corr_data.corr()\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', center=0, \n",
    "            fmt='.2f', square=True, ax=ax, cbar_kws={'label': 'Correlation'})\n",
    "ax.set_title('Feature Correlation Matrix', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('correlation_matrix.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Visualization saved: correlation_matrix.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 13. Key Insights Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
