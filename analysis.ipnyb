    "\n",
    "insights = [\n",
    "    (\"1\", \"Contrarian Strategy Works\", \"Best PnL in Fear/Extreme Fear, worst in Greed/Extreme Greed\"),\n",
    "    (\"2\", \"Statistical Significance\", \"p < 0.001, correlation -0.42\"),\n",
    "    (\"3\", \"Whales vs. Retail\", \"Whales profit more in Fear, lose less in Greed\"),\n",
    "    (\"4\", \"Leverage Risk\", \"Higher leverage in Greed amplifies losses\"),\n",
    "    (\"5\", \"Session Effect\", \"Strongest during US trading hours\"),\n",
